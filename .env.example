# .env.example
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne jamais committer le fichier .env dans Git

# Environnement Symfony (dev, prod, test)
APP_ENV=dev
APP_SECRET=changez_cette_valeur_par_une_chaine_aleatoire_32_chars

# URL de connexion à PostgreSQL
# Format : postgresql://utilisateur:motdepasse@hote:port/nombase
DATABASE_URL="postgresql://cesizen_user:cesizen_password@postgres:5432/cesizen?serverVersion=16&charset=utf8"

# Configuration PostgreSQL (utilisée par docker-compose)
POSTGRES_DB=cesizen
POSTGRES_USER=cesizen_user
POSTGRES_PASSWORD=cesizen_password

# JWT : passphrase pour sécuriser les clés RSA
# Générer avec : openssl rand -base64 32
JWT_PASSPHRASE=changez_cette_passphrase_secrete

# Durée de vie du token JWT (en secondes) : 15 minutes
JWT_TTL=900

# URL de l'API (utilisée pour la configuration CORS)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
